# =============================================================================
# Taro Todo Backend Environment Configuration
# =============================================================================
# Copy this file to .env and modify the values as needed.
#
# For Docker development:
#   1. Run `bun run docker:up` to start PostgreSQL container
#   2. Run `bun run db:generate` to generate migration files
#   3. Run `bun run db:migrate` to apply migrations
#   4. Run `bun run dev` to start the development server
# =============================================================================

# Server configuration
PORT=3000
NODE_ENV=development

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL connection string for Docker development (default)
# This matches the docker-compose.yaml configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taro_todo

# For production or external PostgreSQL, modify as needed:
# DATABASE_URL=postgresql://username:password@host:port/database_name

# =============================================================================
# JWT Configuration
# =============================================================================
# JWT secret key - use a strong, random key in production
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# JWT token expiration (30 days by default)
JWT_EXPIRES_IN=30d

# =============================================================================
# WeChat Mini Program Configuration
# =============================================================================
# Obtain these from WeChat Open Platform (https://mp.weixin.qq.com)
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
