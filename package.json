{
  "name": "taro-todo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:backend": "cd apps/backend && bun dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "2.8.20"
  },
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.11"
  },
  "packageManager": "bun@1.3.11"
}
